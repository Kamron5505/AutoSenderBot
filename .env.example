# === Telegram API (my.telegram.org) ===
API_ID=123456
API_HASH=your_api_hash_here

# === Аккаунт ===
PHONE=+71234567890

# === Сессия ===
SESSION_NAME=forum_sender

# === Настройки рассылки ===
DEFAULT_DELAY=30
MAX_MESSAGES_PER_DAY=50

# === Премиум эмодзи (необязательно) ===
# ID кастомного эмодзи из Telegram Premium
# Как получить: отправь эмодзи в избранное -> посмотри логи
# 0 = не использовать премиум эмодзи
PREMIUM_EMOJI_ID=0

# === Текст сообщения по умолчанию ===
# ВАЖНО: для переноса строк используй двойные кавычки и \n
DEFAULT_AD_TEXT="🔥 Приглашаю в нашего бота!\n\n🚀 Уникальные возможности:\n• Моментальная обработка\n• Круглосуточная поддержка\n• Бесплатный доступ\n\n👉 Переходи: https://t.me/your_bot"
